{
  "expo": {
    "name": "Tesla Tokens Generator",
    "slug": "tesla-tokens-generator",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mtm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.myteslamate.tokens",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "mtm",
            "CFBundleURLSchemes": [
              "mtm"
            ]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.myteslamate.tokens",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "mtm"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "permissions": [
        "android.permission.USE_BIOMETRIC",
        "android.permission.USE_FINGERPRINT"
      ],
      "blockedPermissions": [
        "com.google.android.gms.permission.AD_ID"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permet de déverrouiller MyTeslaMate Tokens avec Face ID."
        }
      ],
      "expo-font",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9604440e-bdb3-4c3b-a62e-c45b25b96a06"
      }
    },
    "owner": "myteslamatecoms-organization"
  }
}
