{
  "expo": {
    "name": "MyTeslaMate Tokens",
    "slug": "myteslamate-tokens",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myteslamate",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "buildNumber": "1",
      "supportsTablet": true,
      "bundleIdentifier": "fr.opcode.myteslamatetokens",
      "infoPlist": {
        "CFBundleURLTypes": [
          {
            "CFBundleURLName": "myteslamate",
            "CFBundleURLSchemes": ["myteslamate"]
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "package": "fr.opcode.myteslamatetokens",
      "intentFilters": [
        {
          "action": "VIEW",
          "data": [{ "scheme": "myteslamate" }],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#111111"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Permet de déverrouiller MyTeslaMate Tokens avec Face ID."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {}
    }
  }
}
